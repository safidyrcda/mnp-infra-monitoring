generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  NON_FAIT
  EN_COURS
  REALISE
  VALIDE
}

enum PhaseType {
  preparation
  passation
  contractualization
  execution
}

enum ActivityType {
  ECOT
  ADMIN
}

model EtapeActivity {
  id          String   @id @default(uuid())
  activityId  String
  etapeId     String
  status      Status?
  commentaire String?
  isApplicable Boolean  @default(true)
  date        DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  etape    Etape    @relation(fields: [etapeId], references: [id], onDelete: Cascade)
  followUps EtapeActivityFollowUp[]

  @@unique([activityId, etapeId])
}

model Etape {
  id        String    @id @default(uuid())
  nom       String
  phaseType PhaseType?

  etapeActivities EtapeActivity[]
}

model Activity {
  id        String   @id @default(uuid())
  name      String
  site      String
  type      ActivityType

  etapeActivities EtapeActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EtapeActivityFollowUp {
  id              String   @id @default(uuid())
  etapeActivityId String
  commentaire     String
  date            DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          Status?
  fichierJoint    String?
  etapeActivity   EtapeActivity @relation(fields: [etapeActivityId], references: [id], onDelete: Cascade)
}