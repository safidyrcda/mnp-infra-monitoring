generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Status {
  NON_FAIT
  EN_COURS
  REALISE
  VALIDE
}

enum PhaseType {
  preparation
  passation
  contractualization
  execution
}

enum ActivityType {
  ECOT
  ADMIN
}

// DATE  : date cible / réelle (ex: date de signature, démarrage)
// PERCENTAGE : taux d'avancement (ex: avancement travaux)
// STATUS : validation d'une étape (ex: DAS approuvé ?)
// DOCUMENT : document produit avec référence (ex: numéro APD, référence contrat)
enum TaskValueType {
  DATE
  PERCENTAGE
  STATUS
  DOCUMENT
}

enum UserActivityRole {
  RESPONSABLE
  VALIDATEUR
  OBSERVATEUR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Activity {
  id        String       @id @default(uuid())
  name      String
  site      String
  type      ActivityType
  phases         Phase[]
  taskActivities TaskActivity[]
  userActivities UserActivity[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Phase {
  id         String    @id @default(uuid())
  type       PhaseType
  order      Int
  activityId String
  activity   Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  startDate DateTime?
  endDate   DateTime?
  tasks Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String        @id @default(uuid())
  name      String
  phaseType PhaseType
  order     Int
  valueType TaskValueType
  taskActivities TaskActivity[]
  phases         Phase[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskActivity {
  id         String @id @default(uuid())
  activityId String
  taskId     String
  status      Status  @default(NON_FAIT)
  isApplicable Boolean @default(true)
  valueString String?   // DOCUMENT : référence du document
  valueNumber Float?    // PERCENTAGE : 0-100
  valueDate   DateTime? // DATE : date cible ou réelle
  commentaire String?
  dueDate     DateTime?
  activity  Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  followUps TaskActivityFollowUp[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([activityId, taskId])
}

model TaskActivityFollowUp {
  id             String @id @default(uuid())
  taskActivityId String
  status      Status?
  valueString String?
  valueNumber Float?
  valueDate   DateTime?
  commentaire String?
  problemDescription String?   // Description du problème rencontré
  proposedSolution   String?   // Solution proposée
  nextAction         String?   // Suite à donner / action planifiée
  fichierJoint String?
  createdById   String?
  createdBy     User?   @relation("createdBy", fields: [createdById], references: [id])
  validatedById String?
  validatedBy   User?   @relation("validatedBy", fields: [validatedById], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  taskActivity TaskActivity @relation(fields: [taskActivityId], references: [id], onDelete: Cascade)
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String
  role     String
  userActivities             UserActivity[]
  taskActivityFollowUpsCreated   TaskActivityFollowUp[] @relation("createdBy")
  taskActivityFollowUpsValidated TaskActivityFollowUp[] @relation("validatedBy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserActivity {
  id         String           @id @default(uuid())
  userId     String
  activityId String
  role       UserActivityRole
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, activityId])
}
