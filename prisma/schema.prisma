// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  NON_FAIT
  EN_COURS
  REALISE
  VALIDE
}

enum PhaseType {
  preparation
  passation
  contractualization
  execution
}

enum ActivityType {
  ECOT
  ADMIN
}

enum StepValueType {
  DATE
  PERCENTAGE
  TEXT
  BOOLEAN
  STATUS
}

enum UserActivityRole {
  RESPONSABLE
  VALIDATEUR
  OBSERVATEUR
}

model Activity {
  id        String   @id @default(uuid())
  name      String
  site      String
  type      ActivityType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases Phase[]
  userActivities UserActivity[]

  stepActivities StepActivity[]
}

model Phase {
  id        String    @id @default(uuid())
  type      PhaseType
  order     Int

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  startDate DateTime?
  endDate   DateTime?

  steps Step[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Step {
  id        String @id @default(uuid())

  name      String
  phaseType PhaseType

  order     Int
  valueType StepValueType

  stepActivities StepActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases Phase[]
}

model StepActivity {
  id String @id @default(uuid())

  activityId String
  stepId     String

  status Status @default(NON_FAIT)

  valueString  String?
  valueNumber  Float?
  valueDate    DateTime?
  valueBoolean Boolean?

  commentaire String?

  isApplicable Boolean @default(true)

  dueDate DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  step     Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  followUps StepActivityFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([activityId, stepId])
}

model StepActivityFollowUp {
  id String @id @default(uuid())

  stepActivityId String

  commentaire String?
  status Status?

  valueString  String?
  valueNumber  Float?
  valueDate    DateTime?

  fichierJoint String?

  createdById String?
  createdBy   User? @relation("createdBy", fields: [createdById], references: [id])

  validatedById String?
  validatedBy   User? @relation("validatedBy", fields: [validatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stepActivity StepActivity @relation(fields: [stepActivityId], references: [id], onDelete: Cascade)
}

model User {
  id String @id @default(uuid())

  email String @unique
  name  String?

  password String

  role String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userActivities UserActivity[]

  stepActivityFollowUpsCreated StepActivityFollowUp[] @relation("createdBy")
  stepActivityFollowUpsValidated StepActivityFollowUp[] @relation("validatedBy")
}

model UserActivity {
  id String @id @default(uuid())

  userId     String
  activityId String

  role UserActivityRole

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, activityId])
}